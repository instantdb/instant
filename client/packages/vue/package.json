{
  "name": "@instantdb/vue",
  "type": "module",
  "version": "0.0.0",
  "description": "Vue client for InstantDB",
  "license": "Apache-2.0",
  "homepage": "https://github.com/instantdb/instant/tree/main/client/packages/vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/instantdb/instant.git",
    "directory": "client/packages/vue"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "vue-tsc --noEmit",
    "build:types": "vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:js": "vite build",
    "build": "rm -rf dist && pnpm build:types && pnpm build:js",
    "dev": "vite build --watch",
    "publish-package": "pnpm pack && npm publish *.tgz --access public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@instantdb/core": "workspace:*",
    "@instantdb/version": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.2.0",
    "vitest": "^2.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
