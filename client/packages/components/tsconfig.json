{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "strict": true,
    "outDir": "dist/tsc",
    "moduleResolution": "nodenext",
    "rootDirs": ["src", "lib"],
    "jsx": "react-jsx",
    "checkJs": false,
    "skipLibCheck": true,
    "strictNullChecks": true
  }
}
